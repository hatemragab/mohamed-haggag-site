# ===========================================================================
# Production environment — copy to .env.prod and fill in REAL values:
#   cp .env.prod.example .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# NEVER commit .env.prod.
# ===========================================================================

# --- JWT secrets (REQUIRED) -------------------------------------------------
# Generate each one with:  openssl rand -hex 32
# Use two DIFFERENT values. Rotating them logs every user out.
JWT_ACCESS_SECRET=CHANGE_ME__openssl_rand_-hex_32
JWT_REFRESH_SECRET=CHANGE_ME__openssl_rand_-hex_32__different_value

# --- Public origins (REQUIRED — exact origins as browsers see them) ---------
# Used for the API CORS allow-list. Keep web + admin + api on the SAME
# registrable domain (e.g. example.com / admin.example.com / api.example.com)
# so SameSite=Lax auth cookies work.
WEB_ORIGIN=https://example.com
ADMIN_ORIGIN=https://admin.example.com

# --- URLs baked into the Next.js browser bundles at BUILD time ---------------
# Changing any NEXT_PUBLIC_* value requires `up -d --build` again.
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_ADMIN_URL=https://admin.example.com
NEXT_PUBLIC_SITE_URL=https://example.com

# --- Cookies / proxy ----------------------------------------------------------
# COOKIE_SECURE must stay true — you are behind HTTPS in production.
COOKIE_SECURE=true
# lax works when web/admin/api share one registrable domain. Only set to
# "none" (requires COOKIE_SECURE=true) if the API lives on a different domain.
COOKIE_SAMESITE=lax
# Behind nginx/Caddy/Traefik so rate limiting & secure cookies see real IPs.
TRUST_PROXY=1

# --- Seeded admin account ------------------------------------------------------
# Password applied to the `admin` user when running the seed
# (docker compose -f docker-compose.prod.yml exec api node dist/seed/seed.js).
# Do NOT leave the dev default (admin123) in production.
ADMIN_PASSWORD=CHANGE_ME__strong_admin_password
