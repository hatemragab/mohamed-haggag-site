# --- required ---
NODE_ENV=development                 # production => strict env validation at boot
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27018/haggag
JWT_ACCESS_SECRET=change-me          # production: openssl rand -hex 32
JWT_REFRESH_SECRET=change-me         # production: openssl rand -hex 32
WEB_ORIGIN=http://localhost:3000     # CORS allow-list
ADMIN_ORIGIN=http://localhost:3001

# --- cookies ---
COOKIE_SECURE=false                  # true behind HTTPS
# COOKIE_SAMESITE=lax                # 'none' if web/admin/api are on different domains (requires COOKIE_SECURE=true)

# --- optional ---
# SWAGGER_ENABLED=false              # disable /docs in production
# TRUST_PROXY=1                      # behind a reverse proxy / load balancer
# ADMIN_USERNAME=admin               # seed: admin credentials
# ADMIN_EMAIL=admin@haggag-academy.com
# ADMIN_PASSWORD=change-me-strong    # seed: REQUIRED in production
